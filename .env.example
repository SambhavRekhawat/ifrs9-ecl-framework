# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored so your secrets never get committed.

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ifrs9
DB_USER=postgres
DB_PASSWORD=changeme

# --- FRED (macroeconomic data) API key (free from fredaccount.stlouisfed.org) ---
FRED_API_KEY=your_fred_api_key_here
